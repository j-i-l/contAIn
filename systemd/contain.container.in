# Podman Quadlet — contain
# This is a TEMPLATE. setup.sh renders it with concrete values into
# /etc/containers/systemd/contain.container
#
# Placeholders (sed/awk-replaced by setup.sh):
#   VOLUME_LINES, PRIMARY_HOME, CONTAINERD_CONFIG, HOST, PORT (public),
#   LISTEN_PORT (port OpenCode binds), LIFECYCLE_UNIT_LINES
#   (StopWhenUnneeded in on-demand mode), LIFECYCLE_CONTAINER_LINES
#   (Notify=healthy in on-demand mode), INSTALL_SECTION ([Install] block in
#   always-on mode, empty in on-demand mode)

[Unit]
Description=contain — Sandboxed AI Agent Container
After=network-online.target
@@LIFECYCLE_UNIT_LINES@@

[Container]
ContainerName=contain
Image=localhost/contain:latest
@@LIFECYCLE_CONTAINER_LINES@@

# The entrypoint runs as root for volume housekeeping,
# then drops to the agent user via setpriv.

# ---------- Bind mounts ----------

# Project directories (read-write, identity mounts: host path == container
# path, SELinux relabel). Identity mounts keep OpenCode session `directory`
# identities canonical across host clients and the attached TUI.
@@VOLUME_LINES@@

# contain generated policy (external_directory allow-list, read-only)
Volume=@@CONTAINERD_CONFIG@@/opencode.json:/etc/contain/opencode.json:ro

# contain configuration (for opencode-tui wrapper)
Volume=@@CONTAINERD_CONFIG@@/config.json:/etc/contain/config.json:ro

# OpenCode global configuration (read-only)
Volume=@@PRIMARY_HOME@@/.config/opencode:/home/agent/.config/opencode:ro

# OpenCode data directory (read-write) — database, auth, logs, snapshots, etc.
Volume=@@PRIMARY_HOME@@/.local/share/opencode:/home/agent/.local/share/opencode:rw

# OpenCode state directory (read-write) — model preferences, prompt history, etc.
Volume=@@PRIMARY_HOME@@/.local/state/opencode:/home/agent/.local/state/opencode:rw

# ---------- Environment ----------
# Point opencode at the contain policy file (higher precedence than global config).
Environment=OPENCODE_CONFIG=/etc/contain/opencode.json
# The healthcheck probes the port OpenCode really listens on.
Environment=CONTAIN_INTERNAL_PORT=@@LISTEN_PORT@@

# ---------- Networking ----------
# Host networking keeps things simple; opencode binds to localhost only.
Network=host

# ---------- Resource limits ----------
PodmanArgs=--memory 2g --pids-limit 100

# ---------- Entrypoint args ----------
# Run OpenCode in server mode (headless HTTP server)
Exec=serve --hostname @@HOST@@ --port @@LISTEN_PORT@@

[Service]
Restart=on-failure
@@INSTALL_SECTION@@
