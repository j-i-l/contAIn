# systemd unit — contain file-ownership watcher
# TEMPLATE: setup.sh renders this into /etc/systemd/system/
#
# Placeholders (sed-replaced by setup.sh):
#   INSTALL_DIR, PRIMARY_USER, AGENT_USER, WATCH_DIRS

[Unit]
Description=contain File Ownership Watcher
After=contain.service
# Follow the container lifecycle: contain.service pulls the watcher up (via
# the WantedBy below) and PartOf stops it together with the container. The
# watcher must NOT Want/Require contain.service itself — an active
# dependent would defeat StopWhenUnneeded in on-demand mode.
PartOf=contain.service

[Service]
Type=simple
ExecStart=@@INSTALL_DIR@@/contain-watcher.sh @@PRIMARY_USER@@ @@AGENT_USER@@ @@WATCH_DIRS@@
Restart=on-failure
RestartSec=5

[Install]
WantedBy=contain.service
