# contain — Sandboxed AI Agent Container Image
# Build: sudo podman build \
#          --build-arg AGENT_UID=<uid> \
#          --build-arg AGENT_GID=<primary_gid> \
#          --build-arg AGENT_GROUP_NAME=<primary_group> \
#          -t contain:latest .
FROM ubuntu:24.04

ARG AGENT_UID
ARG AGENT_GID
ARG AGENT_GROUP_NAME

# Minimal runtime dependencies.
# inotify-tools is included for potential in-container watchers.
# util-linux provides setpriv (used by entrypoint to drop privileges).
RUN apt-get update && apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      fzf \
      git \
      inotify-tools \
      jq \
      ripgrep \
      util-linux \
    && rm -rf /var/lib/apt/lists/*

# Download the opencode binary from GitHub releases.
# Override OPENCODE_VERSION at build time to pin a specific release.
ARG OPENCODE_VERSION=latest
ARG OPENCODE_ARCH
RUN set -e; \
    arch="$OPENCODE_ARCH"; \
    if [ -z "$arch" ]; then \
      arch="$(dpkg --print-architecture)"; \
    fi; \
    case "$arch" in \
      amd64|x86_64) asset_arch="x64" ;; \
      arm64|aarch64) asset_arch="arm64" ;; \
      *) echo "Unsupported OpenCode architecture: $arch" >&2; exit 1 ;; \
    esac; \
    if [ "$OPENCODE_VERSION" = "latest" ]; then \
      url="https://github.com/anomalyco/opencode/releases/latest/download/opencode-linux-${asset_arch}.tar.gz"; \
    else \
      url="https://github.com/anomalyco/opencode/releases/download/v${OPENCODE_VERSION}/opencode-linux-${asset_arch}.tar.gz"; \
    fi; \
    curl -fsSL "$url" -o /tmp/opencode.tar.gz && \
    tar -xzf /tmp/opencode.tar.gz -C /usr/local/bin && \
    chmod 755 /usr/local/bin/opencode && \
    rm /tmp/opencode.tar.gz && \
    opencode serve --help 2>&1 | grep -- --hostname >/dev/null

# Create agent user with a group whose GID matches the primary user's group
# on the host. This allows the agent to read/write files via group permissions
# without requiring a dedicated shared group.
#
# The base image (ubuntu:24.04) already ships several well-known groups
# (e.g. "users" GID 100, "nogroup" GID 65534). We handle four cases:
#   1. Group name exists with the correct GID  -> nothing to do (skip groupadd)
#   2. Group name exists with a different GID  -> fix GID via groupmod
#   3. GID exists under a different name       -> rename that group via groupmod
#   4. Neither name nor GID exists             -> create fresh via groupadd
RUN set -e; \
    if getent group "${AGENT_GROUP_NAME}" >/dev/null 2>&1; then \
      EXISTING_GID=$(getent group "${AGENT_GROUP_NAME}" | cut -d: -f3); \
      if [ "$EXISTING_GID" != "${AGENT_GID}" ]; then \
        groupmod -g "${AGENT_GID}" "${AGENT_GROUP_NAME}"; \
      fi; \
    elif getent group "${AGENT_GID}" >/dev/null 2>&1; then \
      OLD_NAME=$(getent group "${AGENT_GID}" | cut -d: -f1); \
      groupmod -n "${AGENT_GROUP_NAME}" "$OLD_NAME"; \
    else \
      groupadd -g "${AGENT_GID}" "${AGENT_GROUP_NAME}"; \
    fi && \
    useradd -u "${AGENT_UID}" -g "${AGENT_GROUP_NAME}" -m -s /bin/bash agent

# Build-time assertion: fail fast if the agent's GID doesn't match what
# was requested.  This catches silent groupmod/groupadd failures (e.g. GID/name
# collision in the base image).
RUN ACTUAL_GID=$(id -g agent) && \
    echo "Agent identity: $(id agent)" && \
    if [ "$ACTUAL_GID" != "${AGENT_GID}" ]; then \
      echo "FATAL: agent GID=$ACTUAL_GID, expected=${AGENT_GID}"; \
      echo "--- /etc/group ---"; cat /etc/group; \
      exit 1; \
    fi && \
    echo "OK: agent GID=$ACTUAL_GID matches requested AGENT_GID=${AGENT_GID}"

# Persistent tool directory — survives via overlay commits.
# The agent can install linters, language servers, etc. here.
RUN mkdir -p /opt/tools/bin && chown -R agent:"${AGENT_GROUP_NAME}" /opt/tools
ENV PATH="/opt/tools/bin:${PATH}"

# Config directory for the contain policy file.
RUN mkdir -p /etc/contain && chown agent:"${AGENT_GROUP_NAME}" /etc/contain

# OpenCode state directory (needed for runtime state like sessions and model preferences).
RUN mkdir -p /home/agent/.local/state/opencode && \
    chown -R agent:"${AGENT_GROUP_NAME}" /home/agent/.local/state

# OpenCode data directory — bind-mounted from host at runtime.
# Subdirectories (log/, etc.) are created by the entrypoint after the mount.
RUN mkdir -p /home/agent/.local/share/opencode && \
    chown -R agent:"${AGENT_GROUP_NAME}" /home/agent/.local/share/opencode

# Trust all git worktrees regardless of owning uid: project files are owned
# by the primary user's uid while the agent runs under its own uid, which
# otherwise triggers git's "dubious ownership" refusal. That refusal breaks
# OpenCode's project discovery (every session collapses into the fallback
# "global" project) and any in-repo git usage by the agent. Access control
# is enforced by the mount allow-list + group permissions, not by git.
RUN git config --system safe.directory '*'

# TUI attach wrapper script
COPY opencode-tui.sh /usr/local/bin/opencode-tui
RUN chmod 755 /usr/local/bin/opencode-tui

# Entrypoint wrapper — prepares mounted volumes, drops to agent user.
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod 755 /usr/local/bin/entrypoint.sh

# Project directories are bind-mounted at their identical host paths
# (identity mounts); Podman creates the mountpoint skeleton automatically.

# Set SHELL explicitly for OpenCode's bash tool resolution.
ENV SHELL=/bin/bash

WORKDIR /home/agent

# Health check — tests the OpenCode server's /global/health endpoint.
# Reads port from config.json if available, falls back to 3000.
# Interval: 30s, Timeout: 5s, Retries: 3, Start period: 10s (allow time for startup)
HEALTHCHECK --interval=30s --timeout=5s --retries=3 --start-period=10s \
  CMD PORT=$(jq -r '.port // 3000' /etc/contain/config.json 2>/dev/null || echo 3000) && \
      curl -sf "http://127.0.0.1:${PORT}/global/health" || exit 1

# The entrypoint runs as root for volume housekeeping, then drops to agent.
# Do NOT add USER here — the entrypoint handles privilege dropping.
ENTRYPOINT ["entrypoint.sh"]
